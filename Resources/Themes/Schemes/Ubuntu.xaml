<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- FluentTheme system accent overrides -->
    <Color x:Key="SystemAccentColor">#DD4814</Color>
    <Color x:Key="SystemAccentColorDark1">#B83D12</Color>
    <Color x:Key="SystemAccentColorDark2">#933210</Color>
    <Color x:Key="SystemAccentColorLight1">#E25F3A</Color>
    <Color x:Key="SystemAccentColorLight2">#E87A5B</Color>

    <!-- FluentTheme accent brushes (override for runtime switching) -->
    <SolidColorBrush x:Key="SystemControlHighlightAccentBrush">#DD4814</SolidColorBrush>
    <SolidColorBrush x:Key="SystemControlHighlightAltAccentBrush">#DD4814</SolidColorBrush>
    <SolidColorBrush x:Key="SystemControlHighlightBaseHighBrush">#DD4814</SolidColorBrush>
    <SolidColorBrush x:Key="SystemControlHighlightListLowBrush">#3D1A10</SolidColorBrush>
    <SolidColorBrush x:Key="SystemControlHighlightListMediumBrush">#6E2410</SolidColorBrush>
    <SolidColorBrush x:Key="SystemControlForegroundAccentBrush">#DD4814</SolidColorBrush>
    <SolidColorBrush x:Key="SystemControlBackgroundAccentBrush">#DD4814</SolidColorBrush>
    <SolidColorBrush x:Key="SystemControlHighlightChromeHighBrush">#AEA79F</SolidColorBrush>

    <!-- Custom app brushes -->
    <SolidColorBrush x:Key="AccentForegroundBrush">#dd4814</SolidColorBrush>
    <SolidColorBrush x:Key="CommandForegroundBrush">#aea79f</SolidColorBrush>
    <SolidColorBrush x:Key="OverlayBorderBrush">#dd4814</SolidColorBrush>
    <SolidColorBrush x:Key="DataPathForegroundBrush">#dd4814</SolidColorBrush>
    <SolidColorBrush x:Key="OverlayDropForegroundBrush">#dd4814</SolidColorBrush>
    <SolidColorBrush x:Key="LinkForegroundBrush">#dd4814</SolidColorBrush>
</ResourceDictionary>
