<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="LlamaServerLauncher.App"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/llama-launcher.ico"
                     ToolTipText="Llama Server Launcher" />
        </TrayIcons>
    </TrayIcon.Icons>
</Application>