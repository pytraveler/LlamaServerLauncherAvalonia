<Window x:Class="LlamaServerLauncher.DownloadDialogWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LlamaServerLauncher.ViewModels;assembly=LlamaServerLauncher"
        Title="{Binding Localized.DownloadDialogTitle}"
         Width="700" Height="580"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        MinWidth="450" MinHeight="420"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Design.DataContext>
        <vm:DownloadDialogViewModel/>
    </Design.DataContext>

    <TabControl x:Name="MainTabControl" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
        <TabItem Header="{Binding Localized.OfficialTab}">
            <Grid Margin="15" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Text="{Binding Localized.SelectRelease}" FontWeight="Bold" Margin="0,0,0,5"/>

                <ComboBox Grid.Row="1"
                          ItemsSource="{Binding Releases}"
                          SelectedItem="{Binding SelectedRelease}"
                          IsEditable="True"
                          Text="{Binding ManualTagInput, UpdateSourceTrigger=PropertyChanged}"
                          IsEnabled="{Binding !IsDownloading}"
                          Margin="0,0,0,5"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} — {1:yyyy-MM-dd HH:mm}">
                                        <Binding Path="Tag"/>
                                        <Binding Path="PublishedAt"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Border Grid.Row="2"
                        CornerRadius="4" Padding="8" Margin="0,0,0,5"
                        MaxHeight="120"
                        IsVisible="{Binding ReleaseDescription, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Background="{DynamicResource PanelBackgroundBrush}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding ReleaseDescription}"
                                   TextWrapping="Wrap"
                                   Opacity="0.7"
                                   FontSize="12"/>
                    </ScrollViewer>
                </Border>

                <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="Orange" Margin="0,0,0,5"
                           IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <TextBlock Grid.Row="4" Text="{Binding Localized.SelectBuild}" FontWeight="Bold" Margin="0,0,0,5"/>

                <ListBox Grid.Row="5"
                         ItemsSource="{Binding AvailableAssets}"
                         SelectedItem="{Binding SelectedAsset}"
                         IsEnabled="{Binding !IsDownloading}"
                         Margin="0,0,0,10">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} ({1:F1} MB)">
                                        <Binding Path="Name"/>
                                        <Binding Path="SizeMB"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <ProgressBar Grid.Row="6" Minimum="0" Maximum="100"
                             Value="{Binding DownloadProgress}"
                             IsVisible="{Binding ShowProgress}"
                             Margin="0,0,0,10"/>

                <TextBlock Grid.Row="7" Text="{Binding StatusMessage}" Margin="0,0,0,10"
                           IsVisible="{Binding IsDownloading}"/>

                <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{Binding Localized.DownloadButton}" Click="DownloadClick"
                            IsEnabled="{Binding CanDownload}" Width="100" Margin="0,0,10,0"/>
                    <Button Content="{Binding Localized.DownloadToFolder}" Click="DownloadToFolderClick"
                            IsEnabled="{Binding CanDownload}" Width="150" Margin="0,0,10,0"/>
                    <Button Content="{Binding Localized.Cancel}" Click="CancelClick" Width="80"/>
                </StackPanel>
            </Grid>
        </TabItem>

        <TabItem Header="{Binding Localized.ExperimentalTab}" IsEnabled="{Binding HasExperimentalRepos}">
            <Grid Margin="15" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Text="{Binding Localized.ExperimentalRepoSelect}" FontWeight="Bold" Margin="0,0,0,5"
                           IsVisible="{Binding HasExperimentalRepos}"/>

                <ComboBox Grid.Row="1"
                          ItemsSource="{Binding ExperimentalRepos}"
                          SelectedItem="{Binding SelectedExperimentalRepo}"
                          IsEnabled="{Binding !IsDownloading}"
                          Margin="0,0,0,10"
                          HorizontalAlignment="Stretch"
                          IsVisible="{Binding HasExperimentalRepos}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Row="2" Text="{Binding Localized.SelectRelease}" FontWeight="Bold" Margin="0,0,0,5"
                           IsVisible="{Binding HasExperimentalRepos}"/>

                <ComboBox Grid.Row="3"
                          ItemsSource="{Binding ExperimentalReleases}"
                          SelectedItem="{Binding SelectedExperimentalRelease}"
                          IsEnabled="{Binding !IsDownloading}"
                          Margin="0,0,0,5"
                          HorizontalAlignment="Stretch"
                          IsVisible="{Binding HasExperimentalRepos}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} — {1:yyyy-MM-dd HH:mm}">
                                        <Binding Path="Tag"/>
                                        <Binding Path="PublishedAt"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <ListBox Grid.Row="4"
                         ItemsSource="{Binding ExperimentalAssets}"
                         SelectedItem="{Binding SelectedExperimentalAsset}"
                         IsEnabled="{Binding !IsDownloading}"
                         Margin="0,0,0,10"
                         IsVisible="{Binding HasExperimentalRepos}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} ({1:F1} MB)">
                                        <Binding Path="Name"/>
                                        <Binding Path="SizeMB"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <ProgressBar Grid.Row="5" Minimum="0" Maximum="100"
                             Value="{Binding DownloadProgress}"
                             IsVisible="{Binding ShowProgress}"
                             Margin="0,0,0,10"/>

                <TextBlock Grid.Row="6" Text="{Binding StatusMessage}" Margin="0,0,0,10"
                           IsVisible="{Binding IsDownloading}"/>

                <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right"
                            IsVisible="{Binding HasExperimentalRepos}">
                    <Button Content="{Binding Localized.DownloadToFolder}" Click="DownloadExperimentalClick"
                            IsEnabled="{Binding CanDownloadExperimental}" Width="150" Margin="0,0,10,0"/>
                    <Button Content="{Binding Localized.Cancel}" Click="CancelClick" Width="80"/>
                </StackPanel>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
