<Window x:Class="LlamaServerLauncher.ArgumentPickerWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:LlamaServerLauncher.ViewModels;assembly=LlamaServerLauncher"
        mc:Ignorable="d"
        x:DataType="vm:ArgumentPickerViewModel"
        Title="{Binding Localized.ArgumentPickerTitle}"
        Width="750" Height="550"
        MinWidth="500" MinHeight="350"
        WindowStartupLocation="CenterOwner">
    <Design.DataContext>
        <vm:ArgumentPickerViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="10">
        <TextBox Grid.Row="0"
                 Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="{Binding Localized.ArgumentPickerFilter}"
                 Margin="0,0,0,10"/>

        <Grid Grid.Row="1" ColumnDefinitions="Auto,140,*,120" Margin="5,0,0,5">
            <TextBlock Grid.Column="1" Text="{Binding Localized.ArgumentPickerFlag}" FontWeight="Bold" Margin="5,0"/>
            <TextBlock Grid.Column="2" Text="{Binding Localized.ArgumentPickerDescription}" FontWeight="Bold" Margin="5,0"/>
            <TextBlock Grid.Column="3" Text="{Binding Localized.ArgumentPickerDefault}" FontWeight="Bold" Margin="5,0"/>
        </Grid>

        <ListBox Grid.Row="2"
                 ItemsSource="{Binding FilteredArguments}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="Auto,140,*,120"
                          DoubleTapped="ItemDoubleTapped"
                          Background="Transparent">
                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding IsSelected}"
                                  VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding PrimaryFlag}"
                                   Margin="5,0"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Description}"
                                   TextWrapping="Wrap"
                                   Margin="5,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3"
                                   Text="{Binding DefaultValue}"
                                   Margin="5,0"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="{Binding Localized.ArgumentPickerAdd}"
                    Click="AddClick"
                    MinWidth="80"
                    IsDefault="True"/>
            <Button Content="{Binding Localized.ArgumentPickerCancel}"
                    Click="CancelClick"
                    MinWidth="80"
                    Margin="10,0,0,0"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
