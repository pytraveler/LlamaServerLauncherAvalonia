<Window x:Class="LlamaServerLauncher.ArgumentPickerWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:LlamaServerLauncher.ViewModels;assembly=LlamaServerLauncher"
        mc:Ignorable="d"
        x:DataType="vm:ArgumentPickerViewModel"
        Title="{Binding Localized.ArgumentPickerTitle}"
        Width="950" Height="600"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Design.DataContext>
        <vm:ArgumentPickerViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" Margin="10">
        <TextBox Grid.Row="0"
                 Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="{Binding Localized.ArgumentPickerFilter}"
                 Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding GroupedArguments}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="{Binding CategoryName}"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Margin="0,4,0,2"
                                       Opacity="0.8"/>
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="Auto,170,*,120"
                                              DoubleTapped="ItemDoubleTapped"
                                              Background="Transparent"
                                              Margin="0,1">
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected}"
                                                      VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding PrimaryFlag}"
                                                       Margin="5,0"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontFamily="Consolas,Courier New,monospace"/>
                                            <StackPanel Grid.Column="2" Margin="5,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Description}"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding AllowedValuesText}"
                                                           TextWrapping="Wrap"
                                                           FontSize="11"
                                                           Opacity="0.6"
                                                           FontFamily="Consolas,Courier New,monospace"
                                                           IsVisible="{Binding AllowedValuesText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding DefaultValue}"
                                                       Margin="5,0"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontFamily="Consolas,Courier New,monospace"
                                                       Opacity="0.7"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="{Binding Localized.ArgumentPickerAdd}"
                    Click="AddClick"
                    MinWidth="80"
                    IsDefault="True"/>
            <Button Content="{Binding Localized.ArgumentPickerCancel}"
                    Click="CancelClick"
                    MinWidth="80"
                    Margin="10,0,0,0"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
