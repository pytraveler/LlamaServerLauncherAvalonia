<Window x:Class="LlamaServerLauncher.ScenarioDialogWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LlamaServerLauncher.ViewModels;assembly=LlamaServerLauncher"
        Title="{Binding DialogTitle}"
        Width="520" Height="550"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        MinWidth="400" MinHeight="400"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Design.DataContext>
        <vm:ScenarioDialogViewModel/>
    </Design.DataContext>

    <Grid Margin="15" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">
        <TextBlock Grid.Row="0" Text="{Binding Localized.ScenarioName}" Margin="0,0,0,5"/>
        <TextBox Grid.Row="1" Text="{Binding ScenarioName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

        <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,10">
            <StackPanel Margin="0,0,15,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Localized.ScenarioInterval}" Margin="0,0,0,5"/>
                <NumericUpDown Value="{Binding IntervalSeconds}" Minimum="0" Maximum="3600" Width="120"/>
            </StackPanel>
            <CheckBox Grid.Column="1" Content="{Binding Localized.ScenarioAutoStart}" IsChecked="{Binding AutoStart}"
                      VerticalAlignment="Center" Margin="0,20,0,0"/>
        </Grid>

        <TextBlock Grid.Row="3" Text="{Binding Localized.ScenarioProfiles}" Margin="0,0,0,5"/>

        <Grid Grid.Row="4" ColumnDefinitions="*,Auto,*,Auto" Margin="0,0,0,10">
            <ListBox ItemsSource="{Binding AvailableProfiles}"
                     SelectedItem="{Binding SelectedAvailableProfile}"
                     SelectedIndex="{Binding SelectedAvailableProfileIndex}"
                     Grid.Column="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                   ToolTip.Tip="{Binding Summary}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,8,0">
                <Button Content="&#x226B;" Click="AddProfileClick" Width="35" Height="28" Margin="0,0,0,5"
                        IsEnabled="{Binding CanAdd}" ToolTip.Tip="Add"/>
                <Button Content="&#x226A;" Click="RemoveProfileClick" Width="35" Height="28" Margin="0,0,0,5"
                        IsEnabled="{Binding CanRemove}" ToolTip.Tip="Remove"/>
                <Button Content="{Binding Localized.CloneToScenario}" Click="CloneToScenarioClick" Width="55" Height="28"
                        IsEnabled="{Binding CanCloneToScenario}" ToolTip.Tip="Clone to scenario"/>
            </StackPanel>

            <ListBox ItemsSource="{Binding ScenarioProfiles}"
                     SelectedItem="{Binding SelectedScenarioProfile}"
                     SelectedIndex="{Binding SelectedScenarioProfileIndex}"
                     Grid.Column="2">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                   ToolTip.Tip="{Binding Summary}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="8,0,8,0">
                <Button Content="&#x25B2;" Click="MoveUpClick" Width="35" Height="28" Margin="0,0,0,5"
                        IsEnabled="{Binding CanMoveUp}" ToolTip.Tip="Up"/>
                <Button Content="&#x25BC;" Click="MoveDownClick" Width="35" Height="28"
                        IsEnabled="{Binding CanMoveDown}" ToolTip.Tip="Down"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{Binding Localized.Save}" Click="OkClick" Width="90" Margin="0,0,10,0"
                    IsEnabled="{Binding CanSave}"/>
            <Button Content="{Binding Localized.Cancel}" Click="CancelClick" Width="90"/>
        </StackPanel>
    </Grid>
</Window>
