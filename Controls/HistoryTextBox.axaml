<UserControl x:Class="LlamaServerLauncher.Controls.HistoryTextBox"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Grid ColumnDefinitions="*,Auto">
        <TextBox Grid.Column="0"
                 x:Name="InnerTextBox"
                 TextWrapping="NoWrap"/>
        <Button Grid.Column="1"
                x:Name="HistoryButton"
                Margin="2,0,0,0"
                Padding="4"
                VerticalAlignment="Stretch"
                Click="HistoryButton_Click">
            <PathIcon Data="m1619 552l-742 741q-19 19-45 19t-45-19L45 552q-19-19-19-45.5T45 461l166-165q19-19 45-19t45 19l531 531l531-531q19-19 45-19t45 19l166 165q19 19 19 45.5t-19 45.5"/>
        </Button>
    </Grid>
</UserControl>
