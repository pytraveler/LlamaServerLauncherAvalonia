<Window x:Class="LlamaServerLauncher.AboutDialogWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:LlamaServerLauncher.Resources;assembly=LlamaServerLauncher"
        Title="{Binding AboutTitle}"
         Width="480" Height="280"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SizeToContent="Height"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" HorizontalAlignment="Center">
        <TextBlock Grid.Row="0" Text="Llama Server Launcher" FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,10">
            <TextBlock.Text>
                <MultiBinding StringFormat="{}{0}: pytraveler">
                    <Binding Path="Localized.Developer" />
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
            <TextBlock Text="GitHub: " VerticalAlignment="Center"/>
            <Button Content="pytraveler" Click="OpenGitHubProfile" Cursor="Hand"
                    Foreground="{DynamicResource LinkForegroundBrush}" Background="Transparent" BorderThickness="0"
                    Padding="0" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
            <TextBlock Text="{Binding Localized.AppRepository}" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <Button Content="LlamaServerLauncherAvalonia" Click="OpenAppRepository" Cursor="Hand"
                    Foreground="{DynamicResource LinkForegroundBrush}" Background="Transparent" BorderThickness="0"
                    Padding="0" VerticalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="4" Background="{DynamicResource SeparatorBrush}" Height="1" Margin="0,0,0,10" HorizontalAlignment="Stretch"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <TextBlock Text="{Binding Localized.ThanksMethelina}" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <Button Content="Methelina" Click="OpenMethelinaProfile" Cursor="Hand"
                    Foreground="{DynamicResource LinkForegroundBrush}" Background="Transparent" BorderThickness="0"
                    Padding="0" VerticalAlignment="Center"/>
        </StackPanel>

        <Button Grid.Row="6" Content="{Binding Localized.OK}" Click="CloseClick"
                HorizontalAlignment="Center" Padding="30,8" MinWidth="80"/>
    </Grid>
</Window>
